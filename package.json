{
  "name": "agentnative-site",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "agentnative.dev — the agent-native CLI standard",
  "scripts": {
    "build": "bun src/build/build.mjs",
    "dev": "bun run build && wrangler dev --local",
    "test": "bun test",
    "test:e2e": "playwright test",
    "lint": "biome check . && markdownlint-cli2 \"**/*.md\" \"#node_modules\" \"#dist\" \"#docs/solutions\" \"#docs/design\" \"#TODOS.md\" \"#docs/plans\" \"#content\" \"#CHANGELOG.md\" \"#.claude\"",
    "format": "biome format --write .",
    "deploy": "bun run build && wrangler deploy",
    "deploy:dryrun": "bun run build && wrangler deploy --dry-run"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@cloudflare/workers-types": "^4.20260405.1",
    "bun-types": "^1.3.11",
    "markdownlint-cli2": "^0.22.0",
    "typescript": "^6.0.2",
    "wrangler": "^4.81.0"
  }
}
