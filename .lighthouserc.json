{
  "ci": {
    "collect": {
      "startServerCommand": "bun run build && bun x wrangler dev --local --port 8787",
      "startServerReadyPattern": "Ready on http",
      "url": ["http://localhost:8787/p1"],
      "numberOfRuns": 1,
      "settings": {
        "preset": "desktop",
        "chromeFlags": "--no-sandbox --headless=new"
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.9 }],
        "categories:accessibility": ["error", { "minScore": 0.95 }],
        "resource-summary:total:size": ["error", { "maxNumericValue": 400000 }],
        "total-byte-weight": ["warn", { "maxNumericValue": 400000 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
