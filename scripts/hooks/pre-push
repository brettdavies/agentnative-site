#!/usr/bin/env bash
# Pre-push hook — mirrors .github/workflows/ci.yml so a green local push
# almost always means a green CI run. Saves the round-trip of pushing,
# watching CI fail on lint or a broken test, and force-pushing a fix.
#
# Activate once per clone:
#   git config core.hooksPath scripts/hooks
#
# Steps mirror the CI workflow's build job, then add three prose-check
# stages (CI does not run these — pre-push is the only enforcement):
#   1. lint           — biome check + markdownlint-cli2
#   2. build          — bun src/build/build.mjs
#   3. tests          — bun test (unit + regression)
#   4. wrangler       — wrangler deploy --dry-run (config + bundle validation)
#   5. pack-README    — bun scripts/generate-pack-readme.mjs site --check
#                       (drift between styles/site/*.yml and the generated
#                       README; brand pack is vendored and not regenerated)
#   6. banned-fonts   — bash scripts/check-banned-fonts.sh
#                       (deployment-layer scan: CSS, TS, build scripts;
#                       reads tokens from styles/site/BannedFonts.yml)
#   7. prose-check    — bash scripts/prose-check.sh
#                       (Vale + LanguageTool over *.md in scope; LT skips
#                       cleanly when pool is unreachable)
#
# Stages 5-7 each redirect child stdin to </dev/null. The branch-deletion
# short-circuit at the top of the hook consumes the hook-protocol bytes
# from stdin (`while read -r local_ref local_sha …`); a child that read
# stdin would either swallow protocol bytes or fight for them.
#
# To bypass intentionally (rare): `git push --no-verify`. Don't make this
# a habit — the hook is here precisely to catch what we lost time to last.

set -euo pipefail

# Skip the hook for branch deletions (`git push origin --delete <branch>`),
# which arrive with sha=0000... on stdin from the hook protocol.
deleting_only=true
while read -r local_ref local_sha _remote_ref remote_sha; do
  : "$local_ref" "$local_sha" "$_remote_ref" "$remote_sha"
  if [[ "$local_sha" != "0000000000000000000000000000000000000000" ]]; then
    deleting_only=false
  fi
done
if $deleting_only; then
  exit 0
fi

cd "$(git rev-parse --show-toplevel)"

bold() { printf '\033[1m%s\033[0m\n' "$*"; }

bold '==> bun run lint'
bun run lint

bold '==> bun run build'
bun run build

bold '==> bun test'
bun test

bold '==> bun x wrangler deploy --dry-run'
bun x wrangler deploy --dry-run

bold '==> Pack-README drift check'
bun scripts/generate-pack-readme.mjs site --check </dev/null

bold '==> Banned-font deployment scan'
bash scripts/check-banned-fonts.sh </dev/null

bold '==> prose-check (Vale + LanguageTool)'
bash scripts/prose-check.sh </dev/null

bold '==> pre-push checks passed'
